<mapper namespace="dev.mvc.board_report.BoardReportDAOInter">
  <!-- 게시글 신고 등록 -->
  <insert id="create" parameterType="dev.mvc.board_report.BoardReportVO">
    INSERT INTO board_report (board_reportno, boardno, memberno, reason)
    VALUES (board_report_seq.nextval, #{boardno}, #{memberno}, #{reason})
  </insert>

  <!-- 특정 회원이 해당 글을 신고했는지 여부(신고 했으면 1 이상) -->
