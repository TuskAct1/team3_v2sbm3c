        SELECT diaryno, title, content, created_at
        FROM diary
        WHERE SUBSTR(created_at, 1, 7) = #{created_at}
        ORDER BY created_at ASC
    </select>

    &lt;!&ndash; 특정 날짜 조회 &ndash;&gt;
