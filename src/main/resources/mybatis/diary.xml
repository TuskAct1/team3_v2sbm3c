<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="dev.mvc.diary.DiaryDAOInter">

    <!-- 기본 CRUD -->

    <!-- 일기 등록 -->
    <insert id="create" parameterType="dev.mvc.diary.DiaryVO">
        INSERT INTO diary(diaryno, memberno, title, content, password, rdate, risk_flag)
        VALUES(diary_seq.nextval, #{memberno}, #{title}, #{content}, #{password}, SYSDATE, #{risk_flag})
    </insert>

    <!-- 일기 전체 목록 -->
    <select id="list_all" resultType="dev.mvc.diary.DiaryVO">
        SELECT diaryno, memberno, title, content, password, rdate, risk_flag
        FROM diary
    </select>

    <!-- 일기 단일 조회 -->
    <select id="read" resultType="dev.mvc.diary.DiaryVO" parameterType="int">
        SELECT diaryno, memberno, title, content, password, rdate, risk_flag
        FROM diary
        WHERE diaryno = #{diaryno}
    </select>

    <!-- 일기 수정 -->
    <update id="update" parameterType="dev.mvc.diary.DiaryVO">
        UPDATE diary
        SET title = #{title}, content = #{content}, rdate = sysdate, risk_flag = #{risk_flag}
        WHERE diaryno = #{diaryno}
    </update>

    <!-- 일기 삭제 -->
    <delete id="delete" parameterType="int">
        DELETE FROM diary
        WHERE diaryno = #{diaryno}
    </delete>

    <!-- 추가 기능 -->
