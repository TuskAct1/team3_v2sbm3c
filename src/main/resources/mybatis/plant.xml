<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- resources/mapper/plant.xml -->
<mapper namespace="dev.mvc.plant.PlantDAOInter">

  <insert id="create" parameterType="dev.mvc.plant.PlantVO">
    INSERT INTO plant (
      plantno, memberno, plant_name
    ) VALUES (
      #{plantno}, #{memberno}, #{plant_name}
    )
  </insert>

  <!-- 식물 단건 조회 -->
  <select id="read" parameterType="int" resultType="dev.mvc.plant.PlantVO">
    SELECT * FROM plant WHERE plantno = #{plantno}
  </select>

  <!-- 회원 번호로 식물 조회 (필요시) -->
  <select id="readByMemberno" parameterType="int" resultType="dev.mvc.plant.PlantVO">
    SELECT * FROM plant WHERE memberno = #{memberno}
  </select>

  <!-- 식물 정보 수정 -->
  <update id="update" parameterType="dev.mvc.plant.PlantVO">
    UPDATE plant SET plant_name = #{plant_name} WHERE plantno = #{plantno}
  </update>

  <!-- 식물 삭제 -->
  <delete id="delete" parameterType="int">
    DELETE FROM plant WHERE plantno = #{plantno}
  </delete>

</mapper>
