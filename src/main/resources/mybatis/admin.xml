<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dev.mvc.admin.AdminDAOInter">

  <insert id="create" parameterType="dev.mvc.admin.AdminVO">
    INSERT INTO admin(adminno, name, email, password)
    VALUES (admin_seq.nextval, #{name}, #{email}, #{password})
  </insert>

  <select id="login" parameterType="HashMap" resultType="int">
    SELECT COUNT(*) FROM admin 
    WHERE email = #{id} AND password = #{passwd}
  </select>

  <select id="read" resultType="dev.mvc.admin.AdminVO" parameterType="int">
    SELECT * FROM admin WHERE adminno = #{adminno}
  </select>
 
  <!-- <select id="read" resultType="dev.mvc.admin.AdminVO" parameterType="int">
    SELECT adminno, name, email, password
    FROM admin
    WHERE adminno = #{adminno}
  </select> -->

  <select id="readByEmail" resultType="dev.mvc.admin.AdminVO" parameterType="string">
    SELECT * FROM admin WHERE email = #{email}
  </select>

  <select id="list" resultType="dev.mvc.admin.AdminVO">
    SELECT * FROM admin ORDER BY adminno ASC
  </select> 


  <update id="update" parameterType="dev.mvc.admin.AdminVO">
    UPDATE admin
    SET name = #{name}, email = #{email}, password = #{password}
    WHERE adminno = #{adminno}
  </update>



  <select id="checkEmail" parameterType="string" resultType="int">
    SELECT COUNT(*) FROM admin WHERE email = #{email}
  </select>
  
  <delete id="delete" parameterType="int">
    DELETE FROM admin
    WHERE adminno = #{adminno}
  </delete>

</mapper>
